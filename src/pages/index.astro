---
import Booth from '../components/Booth/Booth.astro';
import Wheel from '../components/Wheel/Wheel.astro';
import '../styles/carnival-design-system.css';

const wheelTopics = [
  { id: 'generative', label: 'Generative Art', color: '#3d5c3d', weight: 1.5 },
  { id: 'systems', label: 'Systems', color: '#8b2942', weight: 1.2 },
  { id: 'retro', label: 'Retro Tech', color: '#5a1c2a', weight: 1 },
  { id: 'mental-models', label: 'Mental Models', color: '#2d4a3d', weight: 1 },
  { id: 'economics', label: 'Economics', color: '#4a3728', weight: 0.8 },
  { id: 'games', label: 'Game Dev', color: '#6b4423', weight: 1 },
  { id: 'unfinished', label: '???', color: '#2d2d2d', weight: 0.5 },
  { id: 'placeholder', label: 'Come Back', color: '#3d342b', weight: 0.3 },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>The Booth - William64.com</title>
    <meta name="description" content="Step right up. Spin the wheel. Discover something new." />
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <Booth>
      <Wheel slot="wheel" topics={wheelTopics} />
    </Booth>

    <button class="sound-toggle" id="soundToggle" title="Toggle sound">
      🔊
    </button>

    <script>
      // Sound toggle
      const soundToggle = document.getElementById('soundToggle');
      let soundEnabled = localStorage.getItem('carnivalSound') !== 'false';

      soundToggle?.addEventListener('click', () => {
        soundEnabled = !soundEnabled;
        localStorage.setItem('carnivalSound', soundEnabled.toString());
        soundToggle.textContent = soundEnabled ? '🔊' : '🔇';
      });

      // Check URL for spin result redirect
      const params = new URLSearchParams(window.location.search);
      if (params.get('spun')) {
        // Already spun, maybe show something
        console.log('Spin result detected');
      }
    </script>
  </body>
</html>

<style>
  /* Homepage-specific overrides */
  body {
    background:
      radial-gradient(ellipse at center bottom, #1a1512 0%, #0d0d0d 70%),
      url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    background-blend-mode: soft-light;
    background-size: 100% 100%, 200px 200px;
    opacity: 0;
    animation: fadeIn 0.5s ease forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>
